<html>
  <head>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;800&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="styles.css" />
  </head>
  <body>
    <h1><span class="underline">Where's the ISS? </span></h1>
    <button class="btn">Check below...!</button>
    <section class="orbit-wrapper">
      <div class="orbit-board">
        <div class="orbit-ring"></div>
        <div class="earth"></div>
        <div
          id="iss-dot"
          class="iss-dot absolute w-6 h-6 bg-white rounded-full shadow-[0_0_10px_2px_white]"
          title="ISS"
        ></div>
      </div>
      <p class="orbit-label">
        ISS projected orbit path (approximate, from longitude)
      </p>
    </section>
    <section id="iss-panel" class="iss-panel">
      <h2>ISS Orbit Tracker</h2>
      <div id="iss-status" class="iss-status">Loading ISS position...</div>
      <ul>
        <li><strong>Latitude:</strong> <span id="iss-lat">—</span></li>
        <li><strong>Longitude:</strong> <span id="iss-lon">—</span></li>
        <li><strong>Altitude:</strong> <span id="iss-alt">—</span> km</li>
        <li><strong>Velocity:</strong> <span id="iss-vel">—</span> km/h</li>
        <li><strong>Timestamp:</strong> <span id="iss-time">—</span></li>
        <li><strong>Orbital angle:</strong> <span id="iss-angle">—</span>°</li>
      </ul>
      <p class="iss-note">Updated every 5 seconds.</p>
    </section>
    <script src="space.js"></script>
  </body>
</html>
